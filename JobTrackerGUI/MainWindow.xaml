<Window x:Class="JobTrackerGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Tracker" Height="500" Width="800">

    <Window.Resources>
        <ContextMenu x:Key="NoteContextMenu">
            <MenuItem Header="Edit"   Click="EditNote_Click"   CommandParameter="{Binding}"/>
            <MenuItem Header="Delete" Click="DeleteNote_Click" CommandParameter="{Binding}"/>
        </ContextMenu>
        <ContextMenu x:Key="ContactContextMenu">
            <MenuItem Header="Edit"   Click="EditContact_Click"   CommandParameter="{Binding}"/>
            <MenuItem Header="Delete" Click="DeleteContact_Click" CommandParameter="{Binding}"/>
        </ContextMenu>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <ListBox x:Name="ApplicationsList"
                 SelectionChanged="ApplicationsList_SelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <TextBlock Text="{Binding Company}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding PositionTitle}" Foreground="Gray" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Status:" FontWeight="Bold"/>
            <ComboBox x:Name="StatusEditor"
                      SelectionChanged="StatusEditor_SelectionChanged"
                      Width="150"
                      Margin="0,0,0,10"/>

            <TextBlock Text="Notes:" FontWeight="Bold"/>
            <ListBox x:Name="NotesList" Height="120" Margin="0,5,0,10">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Content}"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="ContextMenu" Value="{StaticResource NoteContextMenu}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <TextBlock Text="Contacts:" FontWeight="Bold" Margin="0,5,0,0"/>
            <ListBox x:Name="ContactsList" Height="120">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding Role}" Foreground="Gray" FontSize="11"/>
                            <TextBlock Text="{Binding Email}" Foreground="Gray" FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="ContextMenu" Value="{StaticResource ContactContextMenu}"/>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>

            <Button Content="Add Application" Click="AddApplication_Click" Margin="0,10,0,0"/>
            <Button Content="Add Note"         Click="AddNote_Click"        Margin="0,5,0,0"/>
            <Button Content="Add Contact"      Click="AddContact_Click"     Margin="0,5,0,0"/>

        </StackPanel>
    </Grid>
</Window>