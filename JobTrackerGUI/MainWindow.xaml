<Window x:Class="JobTrackerGUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Job Tracker" Height="450" Width="800">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

 
        <ListBox x:Name="ApplicationsList" DisplayMemberPath="DisplayName" SelectionChanged="ApplicationsList_SelectionChanged"/>

        <StackPanel Grid.Column="1" Margin="10">
            <TextBlock Text="Notes:" FontWeight="Bold"/>
            <ListBox x:Name="NotesList" Height="100"/>
            <TextBlock Text="Contacts:" FontWeight="Bold" Margin="0,10,0,0"/>
            <ListBox x:Name="ContactsList" Height="100"/>
            <Button Content="Add Application" Click="AddApplication_Click" Margin="0,10,0,0"/>
            <Button Content="Add Note" Click="AddNote_Click" Margin="0,5,0,0"/>
            <Button Content="Add Contact" Click="AddContact_Click" Margin="0,5,0,0"/>
        </StackPanel>
    </Grid>
</Window>